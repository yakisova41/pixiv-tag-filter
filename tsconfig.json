{
  "compilerOptions": {
    "lib": ["ESNext", "dom", "dom.iterable"],
    "module": "esnext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "chrome"],
    "plugins": [],
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules"],
  "typeRoots": ["@types/chrome"]
}
